# ===========================================
# GHOST - Production Environment Variables
# ===========================================
# Copy this file to .env and fill in your keys

# ===========================================
# REQUIRED - AI Analysis
# ===========================================
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# ===========================================
# REQUIRED - YouTube Data
# ===========================================
# Get from: https://console.cloud.google.com/apis/credentials
# 1. Create a project
# 2. Enable "YouTube Data API v3"
# 3. Create an API Key
YOUTUBE_API_KEY=AIza...

# ===========================================
# RECOMMENDED - Apify (cloud YouTube transcripts, no IP blocks)
# ===========================================
# When set, Ghost uses Apify to scrape YouTube videos + transcripts in the cloud,
# so the backend no longer needs the local Mac scraper and won't get IP-blocked.
# Get a token: https://console.apify.com/account/integrations
APIFY_API_TOKEN=apify_api_...
# Actor that scrapes YouTube + subtitles (override to use a different actor).
APIFY_YOUTUBE_ACTOR=streamers~youtube-scraper
# Videos to pull per channel/search term (keeps runs cheap).
APIFY_MAX_RESULTS_PER_QUERY=4
# Optional: full JSON to override the actor input (escape hatch for other actors).
# APIFY_YOUTUBE_INPUT={"startUrls":[...],"maxResults":5}

# ===========================================
# Polymarket - Prediction market odds (public, no key)
# ===========================================
# Surfaces trending finance/crypto/macro prediction markets as signals with REAL
# traded probabilities. Set to "false" to disable.
POLYMARKET_ENABLED=true
# How many finance markets to surface as signals.
POLYMARKET_MAX_MARKETS=12

# ===========================================
# REQUIRED - News Data
# ===========================================
# Get from: https://newsapi.org/register (free tier: 500 req/day)
NEWSAPI_KEY=...

# ===========================================
# RECOMMENDED - Market Data & News
# ===========================================
# Get from: https://polygon.io/dashboard/signup (free tier available)
POLYGON_API_KEY=...

# ===========================================
# RECOMMENDED - Social Sentiment
# ===========================================
# Get from: https://stocktwits.com/developers (free, just register)
# Note: StockTwits doesn't require API key for public endpoints

# ===========================================
# OPTIONAL - Reddit Sentiment (via Quiver)
# ===========================================
# Get from: https://www.quiverquant.com/ (free tier available)
QUIVER_API_KEY=...

# ===========================================
# Server Configuration
# ===========================================
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:3000

# Comma-separated list of allowed CORS origins (production).
# Leave blank for local dev (defaults to localhost:3000).
# Example: https://ghost.yourdomain.com,https://www.ghost.yourdomain.com
ALLOWED_ORIGINS=

# Where the SQLite database lives. On hosted platforms point this at a
# persistent volume, e.g. /data/ghost.db
DATABASE_PATH=data/ghost.db

# ===========================================
# Scraping Configuration
# ===========================================
# How often to fetch new data (in minutes)
FETCH_INTERVAL_MINUTES=30

# Max items to fetch per source per run
MAX_ITEMS_PER_SOURCE=50

# Set to "false" to disable the automatic background fetch scheduler
ENABLE_SCHEDULER=true

# ===========================================
# AI Models (override when Anthropic deprecates a version)
# ===========================================
BULK_MODEL=claude-sonnet-4-5-20250929
INSIGHT_MODEL=claude-opus-4-1-20250805
