# ===========================================
# GHOST Frontend - Environment Variables
# ===========================================
# Copy this file to .env.local for local development.

# Base URL of the Ghost backend API.
# Local dev: http://localhost:8000
# Production: https://your-render-service.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# ===========================================
# Clerk Authentication
# ===========================================
# Get these from https://dashboard.clerk.com -> your app -> API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Where Clerk routes for sign-in / sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/signals
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/signals
